# VenuePilot — environment variables. Copy to .env.local and fill in.
# Never commit real secrets. NEXT_PUBLIC_* values are exposed to the browser.

# --- App / multi-tenant routing -------------------------------------------
# Root domain used by proxy.ts to split marketing / app / tenant hosts.
# Local dev tip: use "lvh.me:3000" (resolves to 127.0.0.1) so subdomains work.
NEXT_PUBLIC_ROOT_DOMAIN="lvh.me:3000"
NEXT_PUBLIC_APP_URL="http://app.lvh.me:3000"

# --- Database (Neon Postgres) ---------------------------------------------
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- Auth (Clerk) ----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Payments (Razorpay) ---------------------------------------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- AI (Anthropic / Claude) ----------------------------------------------
ANTHROPIC_API_KEY=""

# --- Messaging (WhatsApp via BSP / Meta Cloud API) ------------------------
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""

# --- Media storage (Cloudflare R2 / S3) -----------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=""

# --- Background jobs (Inngest) --------------------------------------------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Analytics (PostHog) ---------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Monitoring (Sentry) ---------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Google Maps / Places (audit tool + venue geodata) --------------------
GOOGLE_MAPS_API_KEY=""

# --- Vercel (tenant custom-domain management; Phase 1+) -------------------
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
